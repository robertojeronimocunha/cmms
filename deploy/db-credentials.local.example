# Copie para db-credentials.local e preencha (o arquivo .local está no .gitignore).
# A API FastAPI lê DATABASE_URL em backend/.env — mantenha a mesma senha nos dois
# ou rode: sudo /var/www/html/scripts/change_cmms_db_password.sh (atualiza PG + .env + este arquivo).

PGHOST=127.0.0.1
PGPORT=5432
PGUSER=cmms_app
PGPASSWORD=trocar_senha_forte
PGDATABASE=cmms
DATABASE_URL=postgresql+psycopg2://cmms_app:trocar_senha_forte@127.0.0.1:5432/cmms
