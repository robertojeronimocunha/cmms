APP_NAME="CMMS API"
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=trocar-em-producao
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
# Senha de EXEMPLO só para dev local (cp este arquivo para .env e ajuste).
# Produção: senha forte em .env no servidor; ver readme.md (PostgreSQL).
# Evite '@' na senha ou use %40 na URL.
DATABASE_URL=postgresql+psycopg2://cmms_app:Cmms123@127.0.0.1:5432/cmms
UPLOAD_DIR=backend/uploads
MAX_UPLOAD_SIZE_BYTES=10485760
# Limite do arquivo bruto de imagem antes de redimensionar/JPEG (ex.: foto do celular).
MAX_INGRESS_IMAGE_BYTES=52428800
ALLOWED_UPLOAD_EXTENSIONS=jpg,jpeg,jfif,png,pdf,webp,gif,bmp,tif,tiff,ico,heic,heif,avif
# Opcional — backups pela UI (admin): pastas graváveis por www-data
# CMMS_BACKUP_DB_DIR=/var/www/html/var/backups/db
# CMMS_BACKUP_SYSTEM_DIR=/backup
